{
    "Lua.completion.autoRequire": false,
    "Lua.completion.callSnippet": "Replace",
    "Lua.diagnostics.disable": [],
    "Lua.diagnostics.groupFileStatus": {
        "ambiguity": "Any",
        "await": "Any",
        "duplicate": "Any",
        "global": "Any",
        "luadoc": "Any",
        "redefined": "Any",
        "strict": "Any",
        "strong": "Any",
        "type-check": "Any",
        "unbalanced": "Any",
        "unused": "Any"
    },
    "Lua.hint.setType": false,
    "Lua.runtime.builtin": {
        "basic": "disable",
        "debug": "disable",
        "io": "disable",
        "math": "disable",
        "os": "disable",
        "package": "disable",
        "string": "disable",
        "table": "disable",
        "utf8": "disable",
    },
    "Lua.runtime.version": "Lua 5.1",
    "Lua.workspace.ignoreDir": [
        ".github",
        ".vscode",
        "libs"
    ],
    "Lua.diagnostics.libraryFiles": "Disable",
    "[lua]": {
        "editor.defaultFormatter": "sumneko.lua"
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "editor.formatOnSave": true,
    "editor.indentSize": "tabSize",
    "editor.tabCompletion": "onlySnippets",
    "editor.tabSize": 4,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": true,
    "explorer.fileNesting.patterns": {
        "*.lua": "${capture}.lua, ${capture}.xml",
        "*.toc": ".pkgmeta, .luarc.json, README.md, .gitignore"
    },
    "explorer.sortOrder": "default",
    "peacock.color": "#EBCB8B",
    "workbench.colorCustomizations": {
        "commandCenter.border": "#15202b99",
        "sash.hoverBorder": "#f2deb6",
        "statusBar.background": "#ebcb8b",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#e3b75f",
        "statusBarItem.remoteBackground": "#ebcb8b",
        "statusBarItem.remoteForeground": "#15202b",
        "tab.activeBorder": "#f2deb6",
        "titleBar.activeBackground": "#ebcb8b",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#ebcb8b99",
        "titleBar.inactiveForeground": "#15202b99"
    },
    "wowAPI.luals.configurationScope": "User",
    "wowAPI.luals.defineKnownGlobals": false
}
