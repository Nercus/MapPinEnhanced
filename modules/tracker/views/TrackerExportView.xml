<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">

    <Script file="TrackerExportView.lua" />
    <Frame name="MapPinEnhancedTrackerExportViewTemplate"
        mixin="MapPinEnhancedTrackerExportViewMixin"
        inherits="MapPinEnhancedTrackerViewMixin"
        virtual="true">
        <KeyValues>
            <KeyValue key="viewName" value="Export" type="string" />
            <KeyValue key="gap" value="2" type="number" />
        </KeyValues>
        <Frames>
            <ScrollFrame parentKey="textBox"
                inherits="MapPinEnhancedScrollableTextareaTemplate"
                hidden="true">
                <Size x="300" y="300" />
                <Anchors>
                    <Anchor point="TOPLEFT" x="0" y="0" />
                </Anchors>
            </ScrollFrame>

            <Frame parentKey="exportMode">
                <Size x="300" y="80" />
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"
                        relativeKey="$parent.textBox" />
                </Anchors>
                <Frames>
                    <CheckButton inherits="MapPinEnhancedCheckboxTemplate"
                        parentKey="checkbox"
                        clipChildren="false">
                        <Size x="30" y="30" />
                        <Anchors>
                            <Anchor point="LEFT" x="5" />
                        </Anchors>
                        <Layers>
                            <Layer level="OVERLAY">
                                <FontString inherits="GameFontNormal" parentKey="label"
                                    text="Lock Pin">
                                    <Anchors>
                                        <Anchor point="LEFT" relativePoint="RIGHT" x="2" />
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                    </CheckButton>
                </Frames>
            </Frame>

            <Button parentKey="cancelButton"
                inherits="MapPinEnhancedButtonRedTemplate"
                propagateMouseInput="Motion" hidden="true" text="Cancel">
                <Size x="300" y="30" />
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"
                        relativeKey="$parent.exportMode" />
                </Anchors>
            </Button>
        </Frames>
    </Frame>
</Ui>
