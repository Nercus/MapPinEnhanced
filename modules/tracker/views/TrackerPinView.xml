<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">


    <Script file="TrackerPinView.lua" />
    <ScrollFrame name="MapPinEnhancedTrackerPinViewTemplate"
        mixin="MapPinEnhancedTrackerPinViewMixin"
        virtual="true" inherits="MapPinEnhancedTrackerViewMixin,ScrollFrameTemplate"
        parentKey="scrollFrame" frameStrata="MEDIUM"
        propagateMouseInput="Motion">
        <KeyValues>
            <KeyValue key="viewName" value="Pins" type="string" />
            <KeyValue key="fixedEntryHeight" value="37" type="number" />
            <KeyValue key="parentKey" value="Child" type="string" />
        </KeyValues>
        <Size x="1" y="1" />
        <KeyValues>
            <KeyValue key="scrollBarX" value="0" type="number" />
            <KeyValue key="scrollBarTopY" value="-4" type="number" />
            <KeyValue key="scrollBarHideIfUnscrollable" value="true" type="boolean" />
            <KeyValue key="scrollBarHideTrackIfThumbExceedsTrack" value="true"
                type="boolean" />
        </KeyValues>
        <ScrollChild>
            <Frame parentKey="Child" propagateMouseInput="Motion">
                <Size x="280" y="1" />
                <Anchors>
                    <Anchor point="TOPLEFT" />
                    <Anchor point="BOTTOMRIGHT" />
                </Anchors>
                <Scripts>
                    <OnSizeChanged>
                        self.ScrollBar:Update()
                    </OnSizeChanged>
                </Scripts>
            </Frame>
        </ScrollChild>
    </ScrollFrame>
</Ui>
